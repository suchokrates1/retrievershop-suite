# Global environment configuration for retrievershop-suite
# Copy this file to `.env` and update the values as needed

# API credentials
PAGE_ACCESS_TOKEN=changeme
RECIPIENT_ID=changeme

# Allegro OAuth credentials
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=
ALLEGRO_REDIRECT_URI=
ALLEGRO_ACCESS_TOKEN=
ALLEGRO_REFRESH_TOKEN=

# Printer details
PRINTER_NAME=Xprinter

# CUPS printing server configuration
# Leave these empty when mounting the host's CUPS socket
CUPS_SERVER=
CUPS_PORT=

# General behaviour
POLL_INTERVAL=60
QUIET_HOURS_START=10:00
QUIET_HOURS_END=22:00
TIMEZONE=Europe/Warsaw
PRINTED_EXPIRY_DAYS=5
LOG_LEVEL=INFO
LOG_FILE=agent.log
API_RATE_LIMIT_CALLS=60
API_RATE_LIMIT_PERIOD=60
API_RETRY_ATTEMPTS=3
API_RETRY_BACKOFF_INITIAL=1.0
API_RETRY_BACKOFF_MAX=30.0

# Database location
DB_PATH=/app/data/database.db
# When running inside Docker the database is mounted at ``/app/data/database.db``.
# If you are running locally you may adjust this path or remove the variable
# to rely on the package's default.

# PostgreSQL (ustaw DATABASE_URL aby przejsc na PostgreSQL)
# DATABASE_URL=postgresql://magazyn:HASLO@postgres:5432/magazyn

# Web app settings
SECRET_KEY=changeme

# Platform commission percentages
COMMISSION_ALLEGRO=10.0

# Stock alert configuration
LOW_STOCK_THRESHOLD=1
ALERT_EMAIL=
SMTP_SERVER=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
ENABLE_WEEKLY_REPORTS=1
ENABLE_MONTHLY_REPORTS=1

# Sender data for shipment labels
SENDER_NAME=Alexandra Kaługa
SENDER_COMPANY=Retriever Shop
SENDER_STREET=Wroclawska 15/7
SENDER_CITY=Legnica
SENDER_ZIPCODE=59-220
SENDER_EMAIL=kontakt@retrievershop.pl
SENDER_PHONE=782865895

# Price reports configuration
PRICE_MAX_DISCOUNT_PERCENT=5

# wFirma integration (invoicing)
WFIRMA_ACCESS_KEY=
WFIRMA_SECRET_KEY=
WFIRMA_APP_KEY=
WFIRMA_COMPANY_ID=

# Allegro autoresponder
ALLEGRO_AUTORESPONDER_ENABLED=0
ALLEGRO_AUTORESPONDER_MESSAGE=
